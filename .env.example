# =============================================================
# Fetchy — Discord Media Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================

# ---------------------------
# REQUIRED
# ---------------------------

# Your Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=Your_Bot_Token_Here

# The Discord Channel ID where Fetchy posts its dashboard
# Right-click a channel in Discord → "Copy Channel ID" (Developer Mode must be on)
CHANNEL_ID=123456789012345678

# The public base URL of your server for file download links
# Example for local: http://localhost:8080
# Example for VPS:   http://YOUR_SERVER_IP:8080
BASE_URL=http://YOUR_SERVER_IP:8080

# ---------------------------
# OPTIONAL
# ---------------------------

# Instagram username for authenticated Instaloader sessions
# Required for private posts or to avoid rate limiting
# Leave empty to use anonymous (public posts only)
INSTAGRAM_USERNAME=Your_Instagram_Username_Here

# Path to the Instaloader session file for Instagram authentication.
# Generated by Instaloader: instaloader --login YOUR_USERNAME
# The file is typically at: ~/.config/instaloader/session-YOUR_USERNAME
# For Docker deployments, mount the file and set the path here.
# Leave empty to skip Instagram session injection (public posts only).
INSTAGRAM_SESSION_FILE=

# Path to the Netscape-format cookies file used by yt-dlp and the Instagram scraper.
# Defaults to /app/cookies.txt if not set.
# INSTAGRAM_COOKIES_FILE=/app/cookies.txt

# How often (in seconds) the bot rotates its status message
# Default: 10
STATUS_ROTATION_SPEED=10

# Comma-separated Discord User IDs that bypass ALL rate limits and cooldowns
# Right-click your profile in Discord → "Copy User ID" (Developer Mode must be on)
# Example: ADMIN_IDS=123456789012345678,987654321098765432
ADMIN_IDS=

# Custom regex to detect media links in chat (optional override)
# Default covers YouTube, TikTok, Twitter/X, Instagram
# LINK_REGEX=(https?://)?(www\.)?(youtube\.com|youtu\.be|tiktok\.com|twitter\.com|x\.com|instagram\.com)/[^\s]+
